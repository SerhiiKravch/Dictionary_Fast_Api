APP_NAME=Dictionary FastAPI
APP_DEBUG=false

POSTGRES_DB=dictionary
POSTGRES_USER=dictionary_user
POSTGRES_PASSWORD=dictionary_pass

DATABASE_URL=postgresql+psycopg://dictionary_user:dictionary_pass@localhost:5432/dictionary

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
GZIP_MINIMUM_SIZE=200
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
SECURITY_FRAME_OPTIONS=DENY
SECURITY_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
HTTPS_REDIRECT_ENABLED=false
REQUEST_MAX_BODY_SIZE=100000
SLOW_REQUEST_THRESHOLD_MS=500
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_PATHS=/lookup
